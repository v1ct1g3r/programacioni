@using SistemaPedidos.Core.Models
@using SistemaPedidos.Web.ViewModels

@model CrearPedidoVM

@{
    ViewData["Title"] = "Crear Pedido";
    var productos = ViewBag.Productos as List<Producto> ?? new();
}

<!-- HEADER -->
<div class="page-header mb-4">
    <h1 class="page-title">
        <i class="fas fa-plus-circle me-2"></i>Crear Nuevo Pedido
    </h1>
</div>

<form method="post" id="formPedido">
    <div class="row">
        <!-- COLUMNA PRINCIPAL: PRODUCTOS -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-lg rounded-lg">
                <div class="card-header">
                    <i class="fas fa-cube me-2"></i>
                    <span>Seleccionar Productos</span>
                </div>
                <div class="card-body">
                    @if (productos.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            No hay productos disponibles. <a href="/Productos/Crear">Crear uno primero</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 border-top">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">
                                            <i class="fas fa-check-square"></i>
                                        </th>
                                        <th>Producto</th>
                                        <th style="width: 100px;">Precio</th>
                                        <th style="width: 80px;">Stock</th>
                                        <th style="width: 100px;">Cantidad</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var producto in productos)
                                    {
                                        var tipo = producto is ProductoFisico ? "Físico" : "Digital";
                                        var disponible = producto.Stock > 0;
                                        var iconoTipo = producto is ProductoFisico ? "fas fa-box" : "fas fa-cloud-download-alt";

                                        <tr class="@(!disponible ? "table-secondary" : "")">
                                            <td>
                                                <input type="checkbox" name="ProductosSeleccionados" value="@producto.Id" 
                                                       class="form-check-input" id="producto_@producto.Id" 
                                                       @(!disponible ? "disabled" : "") />
                                            </td>
                                            <td>
                                                <label for="producto_@producto.Id" class="mb-0" style="cursor: pointer;">
                                                    <strong>@producto.Nombre</strong>
                                                    <div style="font-size: 0.85rem;">
                                                        <i class="@iconoTipo me-1"></i>
                                                        <span class="badge bg-secondary">@tipo</span>
                                                    </div>
                                                </label>
                                            </td>
                                            <td class="fw-bold text-heading">$@producto.Precio.ToString("F2")</td>
                                            <td>
                                                @if (disponible)
                                                {
                                                    <span class="badge bg-success">@producto.Stock</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Agotado</span>
                                                }
                                            </td>
                                            <td>
                                                <input type="number" value="0" name="Cantidades[@producto.Id]" min="0" max="@producto.Stock" 
                                                       class="form-control form-control-sm cantidad-input" 
                                                       data-precio="@producto.Precio"
                                                       onchange="validarCantidad(this, @producto.Stock); recalcularTotal();" 
                                                       @(!disponible ? "disabled" : "") />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- COLUMNA LATERAL: PAGO Y RESUMEN -->
        <div class="col-lg-4">
            <!-- MÉTODO DE PAGO -->
            <div class="card shadow-lg rounded-lg mb-4">
                <div class="card-header">
                    <i class="fas fa-credit-card me-2"></i>
                    <span>Método de Pago</span>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3 p-3 border-2 rounded-lg payment-option">
                        <input class="form-check-input" type="radio" name="TipoPago" id="tarjeta" value="tarjeta" checked />
                        <label class="form-check-label w-100" for="tarjeta">
                            <div class="fw-bold mb-1">
                                <i class="fas fa-credit-card me-2"></i>Tarjeta
                            </div>
                            <small class="text-muted">Crédito/Débito</small>
                            <div class="small mt-2 text-warning">
                                <i class="fas fa-info-circle me-1"></i>
                                Límite: $50,000
                            </div>
                        </label>
                    </div>

                    <div class="form-check p-3 border-2 rounded-lg payment-option">
                        <input class="form-check-input" type="radio" name="TipoPago" id="efectivo" value="efectivo" />
                        <label class="form-check-label w-100" for="efectivo">
                            <div class="fw-bold mb-1">
                                <i class="fas fa-coins me-2"></i>Efectivo
                            </div>
                            <small class="text-muted">Pago en efectivo</small>
                        </label>
                    </div>
                </div>
            </div>

            <!-- RESUMEN DE PEDIDO -->
            <div class="card shadow-lg rounded-lg">
                <div class="card-header">
                    <i class="fas fa-receipt me-2"></i>
                    <span>Resumen</span>
                </div>
                <div class="card-body">
                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Productos:</span>
                            <strong id="cantidadProductos">0</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Cantidad Total:</span>
                            <strong id="cantidadTotal">0 unidades</strong>
                        </div>
                    </div>

                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Subtotal:</span>
                            <strong id="subtotal" class="text-heading">$0.00</strong>
                        </div>
                    </div>

                    <div class="alert alert-light mb-3 border">
                        <div class="d-flex justify-content-between align-items-center w-100">
                            <span class="h5 mb-0">Total:</span>
                            <span class="h4 text-primary mb-0" id="totalPedido">$0.00</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-2">
                        <i class="fas fa-check me-2"></i>Procesar Pedido
                    </button>
                    <a href="/Pedidos" class="btn btn-secondary btn-lg w-100">
                        <i class="fas fa-times me-2"></i>Cancelar
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    function validarCantidad(input, stock) {
        const cantidad = parseInt(input.value) || 0;
        if (cantidad > stock) {
            input.value = stock;
            alert(`Solo hay ${stock} unidades disponibles`);
        }
    }

    function recalcularTotal() {
        let cantidadProductos = 0;
        let cantidadTotal = 0;
        let subtotal = 0;

        document.querySelectorAll('.cantidad-input').forEach(input => {
            const cantidad = parseInt(input.value) || 0;
            if (cantidad > 0) {
                cantidadProductos++;
                cantidadTotal += cantidad;
                const precio = parseFloat(input.getAttribute('data-precio'));
                subtotal += cantidad * precio;
            }
        });

        document.getElementById('cantidadProductos').textContent = cantidadProductos;
        document.getElementById('cantidadTotal').textContent = cantidadTotal + ' unidades';
        document.getElementById('subtotal').textContent = '$' + subtotal.toFixed(2);
        document.getElementById('totalPedido').textContent = '$' + subtotal.toFixed(2);
    }
</script>
