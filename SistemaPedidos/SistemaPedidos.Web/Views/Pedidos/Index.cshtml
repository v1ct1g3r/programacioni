@using SistemaPedidos.Core.Interfaces

@model List<PedidoResumenDTO>

@{
    ViewData["Title"] = "Resumen de Pedidos";
}

<!-- HEADER -->
<div class="page-header">
    <h1 class="page-title">
        <i class="fas fa-receipt me-2"></i>Resumen de Pedidos
    </h1>
    <a href="/Pedidos/Crear" class="btn btn-primary btn-lg">
        <i class="fas fa-plus me-2"></i>Nuevo Pedido
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="card border-0 shadow-lg">
        <div class="card-body text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3" style="color: #ccc;"></i>
            <h4 class="mb-2">No hay pedidos registrados</h4>
            <p class="text-muted mb-3">¡Crea tu primer pedido para comenzar!</p>
            <a href="/Pedidos/Crear" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Crear Pedido
            </a>
        </div>
    </div>
}
else
{
    <div class="card shadow-lg rounded-lg">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>
                            <i class="fas fa-hashtag me-2"></i>Pedido
                        </th>
                        <th>
                            <i class="fas fa-calendar me-2"></i>Fecha
                        </th>
                        <th>
                            <i class="fas fa-dollar-sign me-2"></i>Total
                        </th>
                        <th>
                            <i class="fas fa-cube me-2"></i>Productos
                        </th>
                        <th>
                            <i class="fas fa-credit-card me-2"></i>Método de Pago
                        </th>
                        <th>
                            <i class="fas fa-cogs me-2"></i>Acciones
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model)
                    {
                        var metodo = pedido.TipoPago == "tarjeta" 
                            ? "<span class='badge bg-primary'><i class='fas fa-credit-card me-1'></i>Tarjeta</span>"
                            : "<span class='badge bg-warning'><i class='fas fa-coins me-1'></i>Efectivo</span>";

                        <tr class="align-middle">
                            <td>
                                <strong class="text-primary">#@pedido.PedidoId</strong>
                            </td>
                            <td>
                                <i class="fas fa-calendar-alt me-2 text-muted"></i>
                                @pedido.FechaPedido.ToString("dd/MM/yyyy")
                                <br />
                                <small class="text-muted">@pedido.FechaPedido.ToString("HH:mm")</small>
                            </td>
                            <td>
                                <span class="h5 text-heading">$@pedido.Total.ToString("F2")</span>
                            </td>
                            <td>
                                <span class="badge bg-secondary" style="font-size: 0.85rem;">
                                    @pedido.CantidadProductos @(pedido.CantidadProductos == 1 ? "producto" : "productos")
                                </span>
                            </td>
                            <td>
                                @Html.Raw(metodo)
                            </td>
                            <td>
                                <a href="/Pedidos/Detalle/@pedido.PedidoId" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye me-1"></i>Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
