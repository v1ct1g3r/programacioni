@using SistemaPedidos.Core.Interfaces

@model List<PedidoResumenDTO>

@{
    ViewData["Title"] = "Resumen de Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Resumen de Pedidos</h1>
    <a href="/Pedidos/Crear" class="btn btn-primary">+ Nuevo Pedido</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID Pedido</th>
            <th>Fecha</th>
            <th>Total</th>
            <th>Productos</th>
            <th>Método de Pago</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pedido in Model)
        {
            <tr>
                <td><strong>#@pedido.PedidoId</strong></td>
                <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                <td><strong>$@pedido.Total.ToString("F2")</strong></td>
                <td>
                    <span class="badge bg-info">@pedido.CantidadProductos</span>
                </td>
                <td>
                    @if (pedido.TipoPago == "tarjeta")
                    {
                        <span class="badge bg-primary">💳 Tarjeta</span>
                    }
                    else if (pedido.TipoPago == "efectivo")
                    {
                        <span class="badge bg-warning">💵 Efectivo</span>
                    }
                </td>
                <td>
                    <a href="/Pedidos/Detalle/@pedido.PedidoId" class="btn btn-sm btn-info">Ver</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No hay pedidos registrados</div>
}
