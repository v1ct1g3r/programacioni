@model CrearProductoVM

@using SistemaPedidos.Web.ViewModels

@{
    ViewData["Title"] = "Crear Producto";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1>Crear Nuevo Producto</h1>

        <form method="post" class="mt-4">
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label for="Nombre" class="form-label">Nombre del Producto</label>
                        <input type="text" class="form-control" id="Nombre" name="Nombre" required />
                    </div>

                    <div class="mb-3">
                        <label for="Precio" class="form-label">Precio ($)</label>
                        <input type="number" class="form-control" id="Precio" name="Precio" step="0.01" required />
                    </div>

                    <div class="mb-3">
                        <label for="Stock" class="form-label">Stock</label>
                        <input type="number" class="form-control" id="Stock" name="Stock" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo de Producto</label>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="radio" name="Tipo" id="Fisico" value="Fisico" checked 
                                   onchange="mostrarCampos()" />
                            <label class="form-check-label" for="Fisico">Producto Físico</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Tipo" id="Digital" value="Digital" 
                                   onchange="mostrarCampos()" />
                            <label class="form-check-label" for="Digital">Producto Digital</label>
                        </div>
                    </div>

                    <div id="camposFisico" class="mb-3" style="display: block;">
                        <label for="PesoKg" class="form-label">Peso en Kg</label>
                        <input type="number" class="form-control" id="PesoKg" name="PesoKg" step="0.1" />
                    </div>

                    <div id="camposDigital" class="mb-3" style="display: none;">
                        <label for="UrlDescarga" class="form-label">URL de Descarga</label>
                        <input type="url" class="form-control" id="UrlDescarga" name="UrlDescarga" />
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Crear Producto</button>
                <a href="/Productos" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<script>
    function mostrarCampos() {
        const tipo = document.querySelector('input[name="Tipo"]:checked').value;
        document.getElementById('camposFisico').style.display = tipo === 'Fisico' ? 'block' : 'none';
        document.getElementById('camposDigital').style.display = tipo === 'Digital' ? 'block' : 'none';
    }
</script>
