@using SistemaPedidos.Core.Models

@model List<Producto>

@{
    ViewData["Title"] = "Catálogo de Productos";
}

<!-- HEADER -->
<div class="page-header">
    <h1 class="page-title">
        <i class="fas fa-cube me-2"></i>Catálogo de Productos
    </h1>
    <a href="/Productos/Crear" class="btn btn-primary btn-lg">
        <i class="fas fa-plus me-2"></i>Nuevo Producto
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="card border-0 shadow-lg">
        <div class="card-body text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3" style="color: #ccc;"></i>
            <h4 class="mb-2">No hay productos disponibles</h4>
            <p class="text-muted mb-3">¡Crea tu primer producto para comenzar!</p>
            <a href="/Productos/Crear" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Crear Producto
            </a>
        </div>
    </div>
}
else
{
    <!-- GRID DE PRODUCTOS -->
    <div class="row-products">
        @foreach (var producto in Model)
        {
            var iconoTipo = producto is ProductoFisico ? "fas fa-box" : "fas fa-download";
            var badge = producto switch
            {
                ProductoFisico => "<span class='badge bg-primary'><i class='fas fa-box me-1'></i>Físico</span>",
                ProductoDigital => "<span class='badge bg-info'><i class='fas fa-cloud-download-alt me-1'></i>Digital</span>",
                _ => "<span class='badge bg-secondary'>Desconocido</span>"
            };

            var detalle = producto switch
            {
                ProductoFisico pf => $"<small class='text-muted'><i class='fas fa-weight me-1'></i>Peso: {pf.PesoKg} kg</small>",
                ProductoDigital pd => $"<small class='text-muted'><i class='fas fa-link me-1'></i>{pd.UrlDescarga}</small>",
                _ => ""
            };

            <div class="product-card fade-in">
                <div class="product-card-header">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="mb-0">@producto.Nombre</h5>
                        </div>
                        <span>@Html.Raw(badge)</span>
                    </div>
                </div>

                <div class="product-card-body">
                    <div class="mb-3">
                        @Html.Raw(detalle)
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <span class="text-muted small">ID:</span>
                            <span class="badge bg-secondary">#@producto.Id</span>
                        </div>
                        <div class="product-price">
                            $@producto.Precio.ToString("F2")
                        </div>
                    </div>

                    <div class="stock-info mb-3">
                        @if (producto.Stock > 0)
                        {
                            <span class="badge bg-success" style="font-size: 0.95rem;">
                                <i class="fas fa-check-circle me-1"></i>Stock: @producto.Stock unidades
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger" style="font-size: 0.95rem;">
                                <i class="fas fa-times-circle me-1"></i>Agotado
                            </span>
                        }
                    </div>

                    <p class="description mb-3 text-muted small">
                        @producto.ObtenerDescripcion()
                    </p>

                    <button class="btn btn-sm btn-outline-primary w-100" oninput="agregarAlCarrito(@producto.Id)">
                        <i class="fas fa-shopping-cart me-2"></i>Agregar al Pedido
                    </button>
                </div>
            </div>
        }
    </div>
}

