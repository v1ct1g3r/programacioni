@using SistemaPedidos.Core.Models

@model List<Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Catálogo de Productos</h1>
    <a href="/Productos/Crear" class="btn btn-primary">+ Nuevo Producto</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Tipo</th>
            <th>Detalle</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var producto in Model)
        {
            var badge = producto switch
            {
                ProductoFisico => "<span class='badge bg-info'>Físico</span>",
                ProductoDigital => "<span class='badge bg-success'>Digital</span>",
                _ => "<span class='badge bg-secondary'>Desconocido</span>"
            };

            var detalle = producto switch
            {
                ProductoFisico pf => $"Peso: {pf.PesoKg} kg",
                ProductoDigital pd => $"Descarga: {pd.UrlDescarga}",
                _ => ""
            };

            <tr>
                <td>@producto.Id</td>
                <td>@producto.Nombre</td>
                <td>$@producto.Precio.ToString("F2")</td>
                <td>
                    @if (producto.Stock > 0)
                    {
                        <span class="badge bg-success">@producto.Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Agotado</span>
                    }
                </td>
                <td>@Html.Raw(badge)</td>
                <td>@detalle</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No hay productos disponibles</div>
}
